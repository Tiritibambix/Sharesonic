<?xml version="1.0" encoding="utf-8"?>
<!--
    Widget initialLayout: a rounded dark card shown for the split second before
    Glance renders the real content. Because provideGlance no longer blocks on a
    network fetch, the real content replaces this almost immediately — so the
    only thing ever visible pre-render is this rounded card, not square boxes.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg" />
