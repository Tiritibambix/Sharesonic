<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon foreground layer — converted from sharesonic_icon_v8.svg
    (audio waves, centered play button, symmetric shuffle + share glyphs).

    The whole composition is scaled down (×0.15) and recentered so it sits
    inside the adaptive-icon "safe zone" — a circle roughly 66–72dp in
    diameter centered on the 108x108 canvas — so nothing gets clipped by
    circle/squircle/rounded-square launcher masks. The original SVG's own
    rounded-rect background, dot grid and reflection are intentionally
    omitted here; they're reproduced by ic_launcher_background.xml instead.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:scaleX="0.15"
        android:scaleY="0.15"
        android:translateX="6"
        android:translateY="-4">

        <!-- Sound waves — left -->
        <path android:pathData="M 252,258 Q 210,320 252,382" android:strokeWidth="14" android:strokeAlpha="0.9" android:strokeLineCap="round" android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear" android:startX="110" android:startY="580" android:endX="530" android:endY="190" android:startColor="#8b5cf6" android:endColor="#60a5fa"/>
            </aapt:attr>
        </path>
        <path android:pathData="M 214,226 Q 152,320 214,414" android:strokeWidth="11" android:strokeAlpha="0.6" android:strokeLineCap="round" android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear" android:startX="110" android:startY="580" android:endX="530" android:endY="190" android:startColor="#8b5cf6" android:endColor="#60a5fa"/>
            </aapt:attr>
        </path>
        <path android:pathData="M 178,196 Q 96,320 178,444" android:strokeWidth="8" android:strokeAlpha="0.35" android:strokeLineCap="round" android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear" android:startX="110" android:startY="580" android:endX="530" android:endY="190" android:startColor="#8b5cf6" android:endColor="#60a5fa"/>
            </aapt:attr>
        </path>

        <!-- Sound waves — right -->
        <path android:pathData="M 428,258 Q 470,320 428,382" android:strokeWidth="14" android:strokeAlpha="0.9" android:strokeLineCap="round" android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear" android:startX="110" android:startY="580" android:endX="530" android:endY="190" android:startColor="#8b5cf6" android:endColor="#60a5fa"/>
            </aapt:attr>
        </path>
        <path android:pathData="M 466,226 Q 528,320 466,414" android:strokeWidth="11" android:strokeAlpha="0.6" android:strokeLineCap="round" android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear" android:startX="110" android:startY="580" android:endX="530" android:endY="190" android:startColor="#8b5cf6" android:endColor="#60a5fa"/>
            </aapt:attr>
        </path>
        <path android:pathData="M 502,196 Q 584,320 502,444" android:strokeWidth="8" android:strokeAlpha="0.35" android:strokeLineCap="round" android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear" android:startX="110" android:startY="580" android:endX="530" android:endY="190" android:startColor="#8b5cf6" android:endColor="#60a5fa"/>
            </aapt:attr>
        </path>

        <!-- Center hub (navy disc with glow ring) + play triangle -->
        <path android:pathData="M 340,320 m -80,0 a 80,80 0 1,0 160,0 a 80,80 0 1,0 -160,0" android:fillColor="#0f3460" android:strokeWidth="3">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear" android:startX="110" android:startY="580" android:endX="530" android:endY="190" android:startColor="#8b5cf6" android:endColor="#60a5fa"/>
            </aapt:attr>
        </path>
        <path android:pathData="M 317,286 L 317,354 L 389,320 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:type="linear" android:startX="110" android:startY="580" android:endX="530" android:endY="190" android:startColor="#8b5cf6" android:endColor="#60a5fa"/>
            </aapt:attr>
        </path>

        <!-- Shuffle — symmetric crossing arrows (purple ↔ blue) -->
        <path android:pathData="M 115,562 L 141,562 Q 165,562 185,542 L 225,502 Q 245,482 269,482 L 295,482" android:strokeColor="#8b5cf6" android:strokeWidth="10" android:strokeLineCap="round" android:strokeAlpha="0.92" android:fillColor="#00000000"/>
        <path android:pathData="M 293,476 L 301,482 L 293,488 Z" android:fillColor="#8b5cf6" android:fillAlpha="0.92"/>
        <path android:pathData="M 115,482 L 141,482 Q 165,482 185,502 L 225,542 Q 245,562 269,562 L 295,562" android:strokeColor="#60a5fa" android:strokeWidth="10" android:strokeLineCap="round" android:strokeAlpha="0.92" android:fillColor="#00000000"/>
        <path android:pathData="M 293,556 L 301,562 L 293,568 Z" android:fillColor="#60a5fa" android:fillAlpha="0.92"/>

        <!-- Separator -->
        <path android:pathData="M 340,472 L 340,578" android:strokeColor="#2a3a5e" android:strokeWidth="2" android:strokeLineCap="round"/>

        <!-- Share — source node + two recipient nodes -->
        <path android:pathData="M 420,522 m -14,0 a 14,14 0 1,0 28,0 a 14,14 0 1,0 -28,0" android:fillColor="#0f3460" android:strokeColor="#8b5cf6" android:strokeWidth="3"/>
        <path android:pathData="M 502,478 m -14,0 a 14,14 0 1,0 28,0 a 14,14 0 1,0 -28,0" android:fillColor="#0f3460" android:strokeColor="#60a5fa" android:strokeWidth="3"/>
        <path android:pathData="M 502,566 m -14,0 a 14,14 0 1,0 28,0 a 14,14 0 1,0 -28,0" android:fillColor="#0f3460" android:strokeColor="#60a5fa" android:strokeWidth="3"/>
        <path android:pathData="M 433,514 L 489,486" android:strokeWidth="3.5" android:strokeLineCap="round" android:strokeAlpha="0.8" android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear" android:startX="110" android:startY="580" android:endX="530" android:endY="190" android:startColor="#8b5cf6" android:endColor="#60a5fa"/>
            </aapt:attr>
        </path>
        <path android:pathData="M 433,530 L 489,558" android:strokeWidth="3.5" android:strokeLineCap="round" android:strokeAlpha="0.8" android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear" android:startX="110" android:startY="580" android:endX="530" android:endY="190" android:startColor="#8b5cf6" android:endColor="#60a5fa"/>
            </aapt:attr>
        </path>
    </group>
</vector>
