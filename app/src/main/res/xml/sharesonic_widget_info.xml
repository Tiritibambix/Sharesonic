<?xml version="1.0" encoding="utf-8"?>
<!--
    AppWidgetProviderInfo for the Sharesonic home-screen widget.

    - minWidth / minHeight are Android's floor sizes; the widget can go smaller
      only if the launcher lets it. Real rendering picks one of the three
      SizeMode.Responsive buckets defined in SharesonicWidget.kt.
    - targetCellWidth / targetCellHeight are the "default" placement (API 31+).
    - resizeMode = horizontal|vertical lets the user drag either edge.
    - updatePeriodMillis = 0: we drive updates ourselves (Player.Listener +
      widget action callbacks call SharesonicWidget.updateAll). System-driven
      periodic updates would waste battery and can't be scheduled faster than
      30 min anyway.
-->
<appwidget-provider
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="180dp"
    android:minHeight="80dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:minResizeWidth="180dp"
    android:minResizeHeight="80dp"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:updatePeriodMillis="0"
    android:previewLayout="@layout/widget_preview"
    android:initialLayout="@layout/glance_default_loading_layout"
    android:description="@string/widget_description" />
