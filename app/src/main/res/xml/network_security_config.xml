<?xml version="1.0" encoding="utf-8"?>
<!--
  Sharesonic connects to user-specified, self-hosted mStream servers — these are
  very often run on a local network (or even the same device, e.g. inside an
  Android emulator like BlueStacks) without TLS, since mStream itself supports
  plain HTTP out of the box (default port 3000/3001).

  Since Android 9 (API 28), apps default to blocking all cleartext (HTTP)
  traffic — connecting to e.g. http://10.1.1.101:3001 fails with:
    "Cleartext communication to 10.1.1.101 not permitted by network security policy"

  The user picks their own server URL (http:// or https://) in Settings, so we
  must allow cleartext traffic for any destination — there is no fixed domain
  list to scope this to, unlike a service with a known backend.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
